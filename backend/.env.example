#+#+#+#+#####################################################################
# AI Career Intelligence Agent - Backend (.env)
#
# Copy this file to `.env` and adjust values.
#
# IMPORTANT:
# - Use a PostgreSQL URL with the psycopg driver.
# - Example: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
###########################################################################

# App
APP_NAME="AI Career Intelligence Agent"
ENVIRONMENT="local"              # local | staging | production
DEBUG="true"

# Database
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/ai_career_intel"
DB_ECHO="false"
DB_POOL_SIZE="5"
DB_MAX_OVERFLOW="10"

# Dev convenience (do not enable in production)
AUTO_CREATE_TABLES="true"

